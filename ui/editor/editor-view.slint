/// Editor view component for token-based rich text rendering.
///
/// The Rust side computes line and x-offset values, and Slint places each token.
import { RichToken } from "../types.slint";
import { Colors } from "../globals/theme.slint";
import { Spacing } from "../globals/theme.slint";
import { Sizes } from "../state/sizes.slint";
import { Durations } from "../state/durations.slint";
import { ViewStates } from "../state/view-states.slint";

/// Scrollable editor viewport with cursor and active-line visuals.
export component EditorView inherits Rectangle {
    /// Flat token stream with absolute placement metadata.
    in property <[RichToken]> tokens;
    /// Total number of visual lines.
    in property <int> line-count;
    /// Current cursor line index.
    in property <int> cursor-line;
    /// Current cursor column index.
    in property <int> cursor-col;
    /// Width of one monospace character in pixels.
    in property <float> char-width: Sizes.char-width;
    /// Height of one visual line.
    in property <length> line-height: Sizes.line-height;
    /// Font family for the editor.
    in property <string> font-family: "Cascadia Code, Consolas, monospace";

    /// Emitted when the user clicks inside the editor viewport.
    callback editor-clicked(float, float);

    background: Colors.bg-primary;

    Flickable {
        viewport-height: root.line-count * root.line-height;

        TouchArea {
            clicked => { root.editor-clicked(self.mouse-x / Sizes.hairline, (self.mouse-y - parent.viewport-y) / Sizes.hairline); }
        }

        // Active line highlight
        Rectangle {
            x: Sizes.zero;
            y: root.cursor-line * root.line-height;
            width: Sizes.full-pct * Sizes.hairline;
            height: root.line-height;
            background: Colors.highlight;
        }

        // Flat token model where each token is absolutely positioned
        for token in root.tokens : Text {
            x: Spacing.md + (token.x-offset * root.char-width * Sizes.hairline);
            y: token.line-idx * root.line-height;
            text: token.text;
            color: token.token-color;
            font-size: token.font-size * Sizes.hairline;
            font-weight: token.bold ? Sizes.font-weight-bold : Sizes.font-weight-normal;
            font-italic: token.italic;
            font-family: root.font-family;
            height: root.line-height;
            vertical-alignment: center;
        }

        // Cursor
        Rectangle {
            x: Spacing.md + (root.cursor-col * root.char-width * Sizes.hairline);
            y: root.cursor-line * root.line-height + Spacing.xs;
            width: Sizes.caret-width;
            height: root.line-height - Spacing.sm;
            background: Colors.text-primary;

            property <bool> blink-on: true;
            opacity: blink-on ? ViewStates.opacity-on : ViewStates.opacity-off;
            animate opacity { duration: Durations.blink; }

            Timer {
                interval: Durations.blink-interval;
                triggered => { parent.blink-on = !parent.blink-on; }
            }
        }
    }
}
