// Rich text editor — minimal Slint UI.
// Renders via Skia canvas in render notifier callback (not in Slint components).

import { RichToken } from "types.slint";

export { RichToken }

export component AppWindow inherits Window {
    title: "Rich Text Editor";
    width: 900px;
    height: 600px;
    background: #1e1e2e;

    in property <[RichToken]> tokens;
    in property <int> line-count: 0;
    in property <int> cursor-line: 0;
    in property <int> cursor-col: 0;
    in property <image> rendered-content;

    callback editor-clicked(float, float);

    VerticalLayout {
        spacing: 0;

        // Toolbar
        Rectangle {
            height: 40px;
            background: #313244;

            HorizontalLayout {
                padding: 8px;
                spacing: 8px;

                Text {
                    text: "📝 Rich Text Editor";
                    color: #cdd6f4;
                    font-size: 14px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text: "Line: " + root.cursor-line + " Col: " + root.cursor-col;
                    color: #a6adc8;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }

        // Editor area — displays Skia-rendered content
        Rectangle {
            vertical-stretch: 1;
            background: #1e1e2e;

            // Rendered paragraphs from Skia
            Image {
                source: root.rendered-content;
                width: 100%;
                height: 100%;
            }

            TouchArea {
                clicked => {
                    root.editor-clicked(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            }

            // Active line highlight
            Rectangle {
                x: 0;
                y: root.cursor-line * 28px;
                width: 100%;
                height: 28px;
                background: #ffffff10;
            }

            // Cursor
            Rectangle {
                x: 16px + (root.cursor-col * 8.4px);
                y: root.cursor-line * 28px + 4px;
                width: 2px;
                height: 20px;
                background: #cdd6f4;

                property <bool> blink-on: true;
                opacity: blink-on ? 1.0 : 0.0;
                animate opacity { duration: 500ms; }

                Timer {
                    interval: 530ms;
                    triggered => { parent.blink-on = !parent.blink-on; }
                }
            }

            // Debug info
            Text {
                x: 16px;
                y: 8px;
                text: root.tokens.length + " tokens | " + root.line-count + " lines";
                color: #6c7086;
                font-size: 12px;
            }
        }

        // Status bar
        Rectangle {
            height: 32px;
            background: #313244;

            HorizontalLayout {
                padding: 8px;
                spacing: 8px;

                Text {
                    text: "Ready";
                    color: #a6adc8;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text: "Ctrl+S: Save  |  Ctrl+Z: Undo  |  Ctrl+Y: Redo";
                    color: #6c7086;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
    }
}
