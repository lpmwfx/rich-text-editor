/// Fixed sizes — window dimensions, hairlines, percentages.
export global Sizes {
    out property <length> zero:            0px;
    out property <length> hairline:        1px;
    out property <length> caret-width:     2px;
    out property <length> window-width:    900px;
    out property <length> window-height:   600px;
    out property <length> toolbar-height:  40px;
    out property <length> statusbar-height: 32px;
    out property <length> line-height:     28px;
    out property <length> cursor-height:   20px;
    out property <length> font-size-xs:    11px;
    out property <length> font-size-sm:    12px;
    out property <length> font-size-md:    14px;
    out property <float>  char-width:      8.4;
    out property <float>  full-pct:        100;
    out property <float>  half-divisor:    2;
    out property <int>    font-weight-bold:   700;
    out property <int>    font-weight-normal: 400;
}
